{
  "$schema": "https://json.schemas.azure.com/staticwebapp.config.json",
  "routes": [
    { "route": "/api/*", "allowedRoles": ["anonymous"] },
    { "route": "/*",     "allowedRoles": ["anonymous"] }
  ],
  "globalHeaders": {
    "Cache-Control": "no-store",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "no-referrer"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/*.{css,js,svg,png,jpg,ico}"]
  }
}
